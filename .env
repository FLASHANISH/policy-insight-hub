# ============================================
# AI Policy Impact Simulator - Environment Variables
# ============================================

# HuggingFace API Key (used for AI Analysis, Face Match, ChatBox)
# Get your API key from: https://huggingface.co/settings/tokens
VITE_HF_API_KEY=YOUR HUGGINGFACE API HERE

# SerpAPI Key (used for Google Reverse Image Search)
# Get your API key from: https://serpapi.com/manage-api-key
VITE_SERPAPI_KEY=YOY SEROAPI KEY HERE

# imgbb API Key (used to temporarily host image for search)
# Get free key from: https://api.imgbb.com/
VITE_IMGBB_KEY=YOUR IMGBB API KEY 
